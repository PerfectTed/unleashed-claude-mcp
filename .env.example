PORT=3000
NODE_ENV=development

# Optional for local testing/non-Claude clients. Do not set for Claude.ai
# custom connector testing unless OAuth has been added; Claude does not
# support user-pasted bearer tokens or token query params for connectors.
MCP_AUTH_TOKEN=

UNLEASHED_API_ID=
UNLEASHED_API_KEY=
UNLEASHED_BASE_URL=https://api.unleashedsoftware.com
UNLEASHED_CLIENT_TYPE=PerfectTed Claude MCP

# Off by default. Required before non-dry-run purchase order uploads are allowed.
UNLEASHED_ENABLE_WRITE_TOOLS=false
